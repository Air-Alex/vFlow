{
  "name": "JavaScript",
  "scopeName": "source.js",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#storage"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.js",
          "match": "//.*$"
        },
        {
          "name": "comment.block.js",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.js",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.js",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.js",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.js",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.template.js",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.js",
              "match": "\\\\."
            },
            {
              "name": "source.js.embedded.expression",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.js",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.js",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.js",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.decimal.js",
          "match": "\\b(?:\\d+\\.\\d+|\\d+|\\.\\d+)(?:[eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.js",
          "match": "\\b(?:await|break|case|catch|continue|debugger|default|do|else|export|finally|for|from|if|import|in|of|return|switch|throw|try|while|with|yield)\\b"
        },
        {
          "name": "keyword.operator.expression.js",
          "match": "\\b(?:async|delete|instanceof|new|typeof|void)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.type.js",
          "match": "\\b(?:class|const|enum|extends|function|let|static|var)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.js",
          "match": "\\b(?:false|null|super|this|true|undefined)\\b"
        },
        {
          "name": "support.class.builtin.js",
          "match": "\\b(?:Array|Boolean|Date|Error|JSON|Map|Math|Number|Object|Promise|RegExp|Set|String|Symbol|WeakMap|WeakSet)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.js",
          "match": "\\b([A-Za-z_$][\\w$]*)(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.js",
          "match": "(===|!==|==|!=|<=|>=|=>|\\+\\+|--|&&|\\|\\||\\?\\?|[+\\-*/%=&|!<>?:~^])"
        }
      ]
    }
  }
}
